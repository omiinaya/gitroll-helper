# GitRoll Report Exporter - Environment Configuration
# Copy this file to .env and fill in your values

# Your Firebase ID token from GitRoll (see README for how to get this)
FIREBASE_TOKEN=

# Your GitRoll user ID (everything after "profile/" in your GitRoll profile URL)
GITROLL_USER_ID=

# GitHub personal access token with "repo" scope (for create-issues.mjs)
GITHUB_TOKEN=
